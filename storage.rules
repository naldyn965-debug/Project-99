rules_version = '2';
// ═══════════════════════════════════════════════════════════════
//  NABTEX — FIREBASE STORAGE SECURITY RULES
//  Marketplace: users may only upload under their own UID folder
// ═══════════════════════════════════════════════════════════════
service firebase.storage {
  match /b/{bucket}/o {

    // ── MARKETPLACE PRODUCT IMAGES ────────────────────────────
    // Path: marketplace/{userId}/{filename}
    // • Any authenticated user can READ (public product images)
    // • User can only WRITE to their own folder
    // • Max file size 8 MB, images only
    match /marketplace/{userId}/{filename} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.size         <= 8 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ── EXISTING FARM / PROFILE UPLOADS (preserve) ───────────
    match /farm_photos/{userId}/{allPaths=**} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null && request.auth.uid == userId
                    && request.resource.size <= 10 * 1024 * 1024;
    }

    match /profile_photos/{userId}/{allPaths=**} {
      allow read:   if true;
      allow write:  if request.auth != null && request.auth.uid == userId
                    && request.resource.size <= 5 * 1024 * 1024
                    && request.resource.contentType.matches('image/.*');
    }

    // ── DENY ALL ELSE ─────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
