rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()    { return request.auth != null; }
    function isSelf(uid) { return isAuth() && request.auth.uid == uid; }
    function owns(res)   { return isAuth() && request.auth.uid == res.data.ownerId; }
    function ownsOrder(res) {
      return isAuth() && (request.auth.uid == res.data.buyerId ||
                          request.auth.uid == res.data.sellerId);
    }

    // ── USERS ──────────────────────────────────────────────
    match /users/{uid} {
      allow read:  if true;
      allow write: if isSelf(uid);
    }

    // ── FARMS ──────────────────────────────────────────────
    match /farms/{docId} {
      allow read, write: if isAuth();
    }

    // ── PLANTS / DISEASES ──────────────────────────────────
    match /plants/{docId}   { allow read: if true; allow write: if false; }
    match /diseases/{docId} { allow read: if true; allow write: if false; }

    // ── GOALS ──────────────────────────────────────────────
    match /goals/{docId} {
      allow read, write: if isAuth();
    }

    // ── MARKETPLACE ────────────────────────────────────────
    match /marketplace_products/{productId} {
      allow read: if true;
      allow create: if isAuth()
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.price is number;
      allow update: if owns(resource) || isAuth();
      allow delete: if owns(resource);
    }
    match /marketplace_orders/{orderId} {
      allow read:   if ownsOrder(resource);
      allow create: if isAuth() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAuth() && request.auth.uid == resource.data.sellerId;
      allow delete: if false;
    }
    match /marketplace_reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
    match /marketplace_notifications/{notifId} {
      allow read, update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
    }

    // ── SOCIAL: PROFILES ───────────────────────────────────
    // Fields another user can update on your profile (follow counters)
    function isFollowCounterUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['followersCount', 'followingCount']);
    }

    match /social_profiles/{uid} {
      allow read: if true;
      // Owner can update anything; any auth user can update follow counters
      allow write: if isSelf(uid) || (isAuth() && isFollowCounterUpdate());
    }

    // ── SOCIAL: POSTS ──────────────────────────────────────
    // Fields any authenticated user can update (likes, saves, shares)
    function isInteractionUpdate() {
      let allowed = ['likesCount', 'likedBy', 'savedBy', 'sharesCount', 'commentsCount', 'updatedAt'];
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    match /social_posts/{postId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.authorUid == request.auth.uid;
      // Post owner can update anything; any auth user can update likes/saves/shares
      allow update: if isAuth() && (
        resource.data.authorUid == request.auth.uid ||
        isInteractionUpdate()
      );
      allow delete: if isAuth() && resource.data.authorUid == request.auth.uid;
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth();
        allow update: if isAuth() && resource.data.authorUid == request.auth.uid;
        allow delete: if isAuth() && resource.data.authorUid == request.auth.uid;
      }
    }

    // ── SOCIAL: FOLLOWS ────────────────────────────────────
    match /social_follows/{followId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.followerUid == request.auth.uid;
      allow delete: if isAuth() && resource.data.followerUid == request.auth.uid;
    }

    // ── SOCIAL: NOTIFICATIONS ──────────────────────────────
    match /social_notifications/{notifId} {
      allow read, update, delete: if isAuth() && resource.data.toUid == request.auth.uid;
      allow create: if isAuth();
    }

    // ── DENY ALL ELSE ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
