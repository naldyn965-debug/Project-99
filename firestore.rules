rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()    { return request.auth != null; }
    function isSelf(uid) { return isAuth() && request.auth.uid == uid; }
    function owns(res)   { return isAuth() && request.auth.uid == res.data.ownerId; }
    function ownsOrder(res) {
      return isAuth() && (request.auth.uid == res.data.buyerId ||
                          request.auth.uid == res.data.sellerId);
    }

    // ── USERS ──────────────────────────────────────────────
    match /users/{uid} {
      allow read:  if true;
      allow write: if isSelf(uid);
    }

    // ── FARMS ──────────────────────────────────────────────
    // ملاحظة أمان: كانت تسمح لأي مستخدم مسجّل بقراءة/تعديل مزارع
    // الآخرين. تم تقييدها بحقل userId الموجود فعلياً في بيانات المزرعة.
    match /farms/{docId} {
      allow read, update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── FIELDS (حقول المزرعة) ────────────────────────────────
    // لم يكن لها قواعد من قبل، فكانت تُرفض بالكامل بواسطة قاعدة
    // "رفض كل شيء" في آخر الملف — مما يعني عطل فعلي في حفظ الحقول.
    match /fields/{docId} {
      allow read, update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── CROPS (بيانات المحصول) ───────────────────────────────
    match /crops/{docId} {
      allow read, update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── OPERATIONS (التسجيل اليومي/الأرشيف الشهري) ───────────
    match /operations/{docId} {
      allow read, update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── PLANTS / DISEASES ──────────────────────────────────
    match /plants/{docId}   { allow read: if true; allow write: if false; }
    match /diseases/{docId} { allow read: if true; allow write: if false; }

    // ── GOALS ──────────────────────────────────────────────
    match /goals/{docId} {
      allow read, update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // ── EXPENSES (نظام المصروفات: users/{uid}/workers|fertilizers|
    //    pesticides|seeds|irrigation|otherExpenses) ───────────
    // لم يكن لها قواعد من قبل، فكانت تُرفض بالكامل — عطل فعلي في
    // حفظ كل بيانات المصروفات. مقيّدة هنا بمالك الحساب فقط.
    match /users/{uid}/{subcollection}/{docId} {
      allow read, write: if isSelf(uid);
    }

    // ── MARKETPLACE ────────────────────────────────────────
    match /marketplace_products/{productId} {
      allow read: if true;
      allow create: if isAuth()
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.price is number;
      // ملاحظة أمان: كانت "|| isAuth()" تسمح لأي مستخدم مسجّل بتعديل
      // أي منتج. الآن: المالك يعدّل أي حقل، وأي زائر يزيد عدّاد
      // المشاهدات فقط، وأي مستخدم مسجّل يحدّث التقييم فقط (بعد تقييم).
      allow update: if owns(resource)
                    || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views'])
                    || (isAuth() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avgRating','reviewCount']));
      allow delete: if owns(resource);
    }
    match /marketplace_orders/{orderId} {
      allow read:   if ownsOrder(resource);
      allow create: if isAuth() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAuth() && request.auth.uid == resource.data.sellerId;
      allow delete: if false;
    }
    match /marketplace_reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
    match /marketplace_notifications/{notifId} {
      allow read, update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth();
    }

    // ── SOCIAL: PROFILES ───────────────────────────────────
    match /social_profiles/{uid} {
      allow read: if true;
      // Owner writes anything; any auth user can update follow counters only
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) || (
        isAuth() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['followersCount', 'followingCount'])
      );
      allow delete: if isSelf(uid);
    }

    // ── SOCIAL: POSTS ──────────────────────────────────────
    match /social_posts/{postId} {
      allow read: if true;

      allow create: if isAuth()
        && request.resource.data.authorUid == request.auth.uid;

      // Owner: update/delete anything
      // Any auth user: update only interaction fields (like, save, share, comments)
      allow update: if isAuth() && (
        resource.data.authorUid == request.auth.uid
        ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likesCount','likedBy','savedBy','sharesCount','commentsCount'])
      );

      allow delete: if isAuth()
        && resource.data.authorUid == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth();
        allow update: if isAuth() && resource.data.authorUid == request.auth.uid;
        allow delete: if isAuth() && resource.data.authorUid == request.auth.uid;
      }
    }

    // ── SOCIAL: FOLLOWS ────────────────────────────────────
    match /social_follows/{followId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.followerUid == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.followerUid == request.auth.uid;
    }

    // ── SOCIAL: NOTIFICATIONS ──────────────────────────────
    match /social_notifications/{notifId} {
      allow read, update, delete: if isAuth()
        && resource.data.toUid == request.auth.uid;
      allow create: if isAuth();
    }

    // ── DENY ALL ELSE ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
