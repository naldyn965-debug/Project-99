rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()       { return request.auth != null; }
    function isSelf(uid)    { return isAuth() && request.auth.uid == uid; }
    function owns(resource) { return isAuth() && request.auth.uid == resource.data.ownerId; }
    function ownsOrder(res) { return isAuth() &&
        (request.auth.uid == res.data.buyerId ||
         request.auth.uid == res.data.sellerId); }

    // ── EXISTING ─────────────────────────────────────────────
    match /users/{uid} {
      allow read:  if true;
      allow write: if isSelf(uid);
    }
    match /farms/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth();
    }
    match /plants/{docId}   { allow read: if true; allow write: if false; }
    match /diseases/{docId} { allow read: if true; allow write: if false; }
    match /goals/{docId} {
      allow read, write: if isAuth();
    }

    // ── MARKETPLACE PRODUCTS (images stored as Base64 inside doc) ──
    match /marketplace_products/{productId} {
      allow read:   if true;
      allow create: if isAuth()
                    && request.resource.data.ownerId == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.price is number;
      allow update: if owns(resource) || isAuth();
      allow delete: if owns(resource);
    }

    // ── ORDERS ───────────────────────────────────────────────
    match /marketplace_orders/{orderId} {
      allow read:   if ownsOrder(resource);
      allow create: if isAuth() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAuth() && request.auth.uid == resource.data.sellerId;
      allow delete: if false;
    }

    // ── REVIEWS ──────────────────────────────────────────────
    match /marketplace_reviews/{reviewId} {
      allow read:   if true;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && request.auth.uid == resource.data.userId;
    }

    // ── NOTIFICATIONS ────────────────────────────────────────
    match /marketplace_notifications/{notifId} {
      allow read, update, delete: if isAuth() && request.auth.uid == resource.data.userId;
      allow create: if isAuth();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
